# =============================================================================
# News Reader — Root environment variables (example)
# =============================================================================
# For LOCAL DEV: copy this file to `.env` at the project root, or set the
# same variables in each service's own `.env`. NEVER commit the real `.env`.
#
# For PRODUCTION (Vercel): set THENEWSAPI_KEY via `vercel env add` or the
# Vercel dashboard. The other variables only matter for the multi-process
# local dev stack (Express proxy + Go scorer + Vite). The serverless
# functions under /api use process.env.THENEWSAPI_KEY directly.
# -----------------------------------------------------------------------------

# --- Express proxy (./proxy/.env) ------------------------------------------
# Your TheNewsAPI key. Get one at https://www.thenewsapi.com
THENEWSAPI_KEY=replace_me_with_your_thenewsapi_key

# Port the Express proxy listens on (default: 4000)
PROXY_PORT=4000

# URL of the Go scorer service that the proxy forwards stories to for ranking
SCORER_URL=http://localhost:4100

# Comma-separated list of allowed CORS origins for the proxy
ALLOWED_ORIGINS=http://localhost:5173

# --- Go scorer service (./services) ----------------------------------------
# Port the Go scorer listens on (default: 4100)
SCORER_PORT=4100

# --- Client (./client) -----------------------------------------------------
# Base URL the client uses to reach the Express proxy.
# In dev, Vite proxies /api → http://localhost:4000 so this is optional.
VITE_API_BASE_URL=http://localhost:4000
