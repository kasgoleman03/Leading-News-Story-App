# Copy this file to `.env` inside the /proxy folder. NEVER commit the real .env.

# Your TheNewsAPI key. The proxy is the ONLY place this should ever live.
THENEWSAPI_KEY=replace_me_with_your_thenewsapi_key

# Port this proxy listens on
PROXY_PORT=4000

# URL of the Go scorer service. The proxy forwards raw stories here for ranking.
SCORER_URL=http://localhost:4100

# Comma-separated CORS allowlist (the Vite dev server origin by default)
ALLOWED_ORIGINS=http://localhost:5173
