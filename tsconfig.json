{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    /*
     * CommonJS output is the most reliable runtime format for Vercel's
     * @vercel/node serverless functions. The root package.json has no
     * "type": "module" field, so Node loads compiled .js files as CJS by
     * default. Matching the two avoids the "Cannot use import statement
     * outside a module" runtime error that surfaces when tsconfig emits
     * ESM but package.json says CJS.
     */
    "module": "CommonJS",
    "moduleResolution": "node",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["api/**/*.ts"],
  "exclude": [
    "node_modules",
    "client",
    "proxy",
    "services",
    "scripts",
    "**/dist",
    "**/build"
  ]
}
