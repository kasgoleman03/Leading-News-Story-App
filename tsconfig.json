{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    /*
     * NodeNext + "type": "module" in package.json is the modern ESM TS
     * setup that maps 1:1 to how Node (and Vercel's @vercel/node esbuild
     * pipeline) actually loads files at runtime. Relative imports must
     * carry explicit .js extensions — TypeScript understands `./foo.js`
     * to mean "the .ts file that compiles to foo.js", and Node's ESM
     * resolver then finds the right .js at runtime without surprises.
     */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["api/**/*.ts"],
  "exclude": [
    "node_modules",
    "client",
    "proxy",
    "services",
    "scripts",
    "**/dist",
    "**/build"
  ]
}
